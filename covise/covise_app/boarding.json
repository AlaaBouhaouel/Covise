{
  "flow_name": "CoVise Waitlist Onboarding",
  "steps": [
    {
      "step_id": "S2",
      "title": "Your profile",
      "description": "This determines the path of your application.",
      "fields": [
        {
          "id": "user_type",
          "type": "single_select_card",
          "label": "What best describes your profile?",
          "required": true,
          "options": [
            {
              "value": "founder",
              "label": "Founder",
              "description": "I have a venture and I'm looking for a co-founder"
            },
            {
              "value": "specialist",
              "label": "Specialist / Operator",
              "description": "I have skills and want to co-found the right venture"
            },
            {
              "value": "investor",
              "label": "Investor",
              "description": "I'm looking to connect with and back GCC founders"
            },
            {
              "value": "foreign_founder",
              "label": "Foreign Founder",
              "description": "I'm based outside the GCC and seeking a local co-founder or partner"
            },
            {
              "value": "incubator",
              "label": "Incubator / Accelerator",
              "description": "We support startups and want to connect with GCC founders"
            }
          ]
        }
      ]
    },
    {
      "step_id": "S3_founder",
      "title": "Your venture",
      "description": "Share the core details of your startup and what you need in a co-founder.",
      "show_if": {
        "field": "user_type",
        "equals": "founder"
      },
      "fields": [
        {
          "id": "industry",
          "type": "single_select_searchable",
          "label": "Industry",
          "required": true,
          "options": [
            "SaaS / B2B Software",
            "Fintech",
            "E-commerce",
            "AI / ML",
            "Marketplace",
            "Health / Medtech",
            "Education / Edtech",
            "Logistics / Supply Chain",
            "Real Estate / Proptech",
            "Food & Beverage",
            "Travel / Hospitality",
            "Retail / Fashion",
            "Media / Content",
            "Gaming",
            "Cybersecurity",
            "Hardware / IoT",
            "Climate / Energy",
            "Construction / Infrastructure",
            "Legal / Regtech",
            "HR / Future of Work",
            "Agri / Foodtech",
            "Consumer Apps",
            "Import / Export",
            "Other"
          ]
        },
        {
          "id": "stage",
          "type": "single_select",
          "label": "Current stage of your venture",
          "required": true,
          "options": [
            "Idea",
            "MVP built",
            "Early revenue",
            "Profitable / Scaling"
          ]
        },
        {
          "id": "target_market",
          "type": "multi_select",
          "label": "Primary target market",
          "required": true,
          "options": [
            "Saudi Arabia",
            "UAE",
            "Qatar",
            "Kuwait",
            "Bahrain",
            "Oman",
            "GCC-wide",
            "MENA-wide",
            "Global"
          ]
        },
        {
          "id": "team_size",
          "type": "single_select",
          "label": "Current team size (excluding yourself)",
          "required": true,
          "options": [
            "Solo",
            "1-2 others",
            "3-5 others",
            "6+"
          ]
        },
        {
          "id": "one_liner",
          "type": "multi_line_text",
          "label": "Venture overview",
          "required": true,
          "placeholder": "What you are building, who it is for, and what problem it solves",
          "max_chars": 300
        },
        {
          "id": "cofounders_needed",
          "type": "single_select",
          "label": "How many co-founders are you looking for?",
          "required": true,
          "options": [
            "1",
            "2",
            "Open to discussion"
          ]
        },
        {
          "id": "looking_for_type",
          "type": "multi_select",
          "label": "What type of co-founder or partner are you seeking?",
          "required": true,
          "max_selected": 3,
          "options": [
            "Technical co-founder",
            "Business / operational co-founder",
            "Industry expert co-founder",
            "Investor / backer",
            "Strategic advisor",
            "Local GCC partner"
          ]
        },
        {
          "id": "founder_timeline",
          "type": "single_select",
          "label": "How soon are you looking to bring a co-founder on board?",
          "required": true,
          "options": [
            "Immediately",
            "Within 1–3 months",
            "Within 3–6 months",
            "No fixed timeline"
          ]
        }
      ]
    },
    {
      "step_id": "S3_specialist",
      "title": "Your background",
      "description": "Tell us about your expertise, the type of venture you want to build, and your availability.",
      "show_if": {
        "field": "user_type",
        "equals": "specialist"
      },
      "fields": [
        {
          "id": "current_role",
          "type": "single_select",
          "label": "Current or most recent role",
          "required": true,
          "options": [
            "Software Engineer",
            "Product Manager",
            "UX / UI Designer",
            "Data Scientist / AI Engineer",
            "Marketing Manager",
            "Sales / Business Development",
            "Operations Manager",
            "Finance / CFO",
            "Legal / Compliance",
            "Consultant",
            "Other"
          ]
        },
        {
          "id": "years_experience",
          "type": "single_select",
          "label": "Years of professional experience",
          "required": true,
          "options": [
            "0–2 years",
            "3–5 years",
            "6–10 years",
            "10+ years"
          ]
        },
        {
          "id": "industries_interested",
          "type": "multi_select_searchable",
          "label": "Industries you want to build in",
          "required": true,
          "max_selected": 5,
          "options": [
            "SaaS / B2B Software",
            "Fintech",
            "E-commerce",
            "AI / ML",
            "Marketplace",
            "Health / Medtech",
            "Education / Edtech",
            "Logistics / Supply Chain",
            "Real Estate / Proptech",
            "Food & Beverage",
            "Travel / Hospitality",
            "Retail / Fashion",
            "Media / Content",
            "Gaming",
            "Cybersecurity",
            "Hardware / IoT",
            "Climate / Energy",
            "Construction",
            "Legal / Regtech",
            "HR / Future of Work",
            "Consumer Apps",
            "Open to any industry"
          ]
        },
        {
          "id": "venture_stage_preference",
          "type": "multi_select",
          "label": "What stage of venture do you want to join?",
          "required": true,
          "options": [
            "Idea stage",
            "MVP built",
            "Early revenue",
            "Any stage"
          ]
        },
        {
          "id": "founder_type_preference",
          "type": "multi_select",
          "label": "What type of founder are you looking to work with?",
          "required": true,
          "max_selected": 3,
          "options": [
            "Technical founder looking for business co-founder",
            "Business founder looking for technical co-founder",
            "Domain expert founder",
            "Foreign founder entering GCC",
            "Open to any founder profile"
          ]
        },
        {
          "id": "specialist_timeline",
          "type": "single_select",
          "label": "How soon are you ready to commit to a venture?",
          "required": true,
          "options": [
            "Immediately",
            "Within 1–3 months",
            "Within 3–6 months",
            "No fixed timeline"
          ]
        }
      ]
    },
    {
      "step_id": "S3_investor",
      "title": "Your investment profile",
      "description": "Define your investment focus, geography, ticket size, and current deployment status.",
      "show_if": {
        "field": "user_type",
        "equals": "investor"
      },
      "fields": [
        {
          "id": "investor_type",
          "type": "single_select",
          "label": "Investor type",
          "required": true,
          "options": [
            "Angel investor",
            "Venture capital",
            "Family office",
            "Strategic investor",
            "Other"
          ]
        },
        {
          "id": "investment_geography",
          "type": "multi_select",
          "label": "Geographies you actively invest in",
          "required": true,
          "options": [
            "Saudi Arabia",
            "UAE",
            "Qatar",
            "Kuwait",
            "Bahrain",
            "Oman",
            "GCC-wide",
            "MENA-wide",
            "Global"
          ]
        },
        {
          "id": "ticket_size",
          "type": "single_select",
          "label": "Typical ticket size (USD)",
          "required": true,
          "options": [
            "Under $25K",
            "$25K – $100K",
            "$100K – $500K",
            "$500K – $2M",
            "$2M+",
            "Prefer not to say"
          ]
        },
        {
          "id": "investment_stage",
          "type": "multi_select",
          "label": "Stages you invest in",
          "required": true,
          "options": [
            "Pre-seed",
            "Seed",
            "Series A",
            "Series B+",
            "All stages"
          ]
        },
        {
          "id": "investment_industries",
          "type": "multi_select_searchable",
          "label": "Industries of interest",
          "required": true,
          "max_selected": 6,
          "options": [
            "SaaS / B2B Software",
            "Fintech",
            "E-commerce",
            "AI / ML",
            "Marketplace",
            "Health / Medtech",
            "Education / Edtech",
            "Logistics / Supply Chain",
            "Real Estate / Proptech",
            "Food & Beverage",
            "Retail",
            "Media / Content",
            "Climate / Energy",
            "Consumer Apps",
            "Industry agnostic"
          ]
        },
        {
          "id": "investor_value_add",
          "type": "multi_select",
          "label": "Beyond capital, what do you offer portfolio founders?",
          "required": true,
          "max_selected": 4,
          "options": [
            "Strategic advisory",
            "Hiring / team building",
            "Business development",
            "Follow-on funding",
            "Regulatory / legal guidance",
            "Market access",
            "Media / PR exposure",
            "Technical expertise"
          ]
        },
        {
          "id": "investor_looking_for",
          "type": "single_select",
          "label": "Primary objective on CoVise",
          "required": true,
          "options": [
            "Source deal flow",
            "Co-invest with other investors",
            "Mentor and support founders",
            "All of the above"
          ]
        },
        {
          "id": "investor_timeline",
          "type": "single_select",
          "label": "Current deployment status",
          "required": true,
          "options": [
            "Actively deploying capital now",
            "Deploying within 1–3 months",
            "Deploying within 3–6 months",
            "Exploring — no fixed timeline"
          ]
        }
      ]
    },
    {
      "step_id": "S3_foreign_founder",
