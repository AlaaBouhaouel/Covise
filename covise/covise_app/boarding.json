          ]
        },
        {
          "id": "incubator_looking_for",
          "type": "single_select",
          "label": "Primary objective on CoVise",
          "required": true,
          "options": [
            "Source founders for our program",
            "Help our portfolio founders find co-founders",
            "Partner with other programs and ecosystems",
            "All of the above"
          ]
        },
        {
          "id": "incubator_timeline",
          "type": "single_select",
          "label": "Next cohort or intake opening",
          "required": true,
          "options": [
            "Currently open",
            "Within 1–3 months",
            "Within 3–6 months",
            "No fixed schedule"
          ]
        }
      ]
    },
    {
      "step_id": "S4",
      "title": "What you bring",
      "description": "Select the skills you contribute to a venture team.",
      "show_if": {
        "any_of": [
          {
            "field": "user_type",
            "equals": "founder"
          },
          {
            "field": "user_type",
            "equals": "specialist"
          },
          {
            "field": "user_type",
            "equals": "foreign_founder"
          }
        ]
      },
      "fields": [
        {
          "id": "skills",
          "type": "multi_select_searchable",
          "label": "Your top skills",
          "required": true,
          "max_selected": 8,
          "options": [
            "Software Engineering",
            "Full-stack Development",
            "Frontend (React / Next.js)",
            "Backend (Node / Python / Java)",
            "Mobile (iOS / Android / Flutter)",
            "DevOps / Cloud",
            "Data Engineering",
            "AI / ML Engineering",
            "LLMs / Prompting",
            "Data Science",
            "Cybersecurity",
            "Product Management",
            "UX / UI Design",
            "Growth Marketing",
            "Performance Marketing",
            "Branding",
            "Sales",
            "Business Development",
            "Partnerships",
            "Operations",
            "Strategy",
            "Finance",
            "Fundraising",
            "Legal / Compliance",
            "HR / Hiring",
            "Supply Chain",
            "Customer Success",
            "Community Building",
            "Content / Copywriting",
            "Industry Expertise",
            "Other"
          ]
        },
        {
          "id": "availability",
          "type": "single_select",
          "label": "Weekly time commitment to a new venture",
          "required": true,
          "options": [
            "Under 5 hours per week",
            "5–10 hours per week",
            "10–20 hours per week",
            "Full-time"
          ]
        },
        {
          "id": "capital_contribution",
          "type": "single_select",
          "label": "Are you able to contribute capital to the venture?",
          "required": true,
          "options": [
            "No",
            "Yes — under $10K",
            "Yes — $10K to $50K",
            "Yes — $50K+",
            "Prefer to discuss"
          ]
        }
      ]
    },
    {
      "step_id": "S5",
      "title": "Who you are looking for",
      "description": "Define the profile, skills, and commitment level you need in a co-founder.",
      "show_if": {
        "any_of": [
          {
            "field": "user_type",
            "equals": "founder"
          },
          {
            "field": "user_type",
            "equals": "foreign_founder"
          }
        ]
      },
      "fields": [
        {
          "id": "looking_for_skills",
          "type": "multi_select_searchable",
          "label": "Skills your co-founder must bring",
          "required": true,
          "max_selected": 6,
          "options": [
            "Software Engineering",
            "Full-stack Development",
            "Mobile Development",
            "AI / ML Engineering",
            "DevOps / Cloud",
            "Data Science",
            "Product Management",
