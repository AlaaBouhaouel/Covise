            "Sales & business development",
            "Regulatory & legal navigation",
            "Investor & funding connections",
            "Cultural & language bridge"
          ]
        },
        {
          "id": "foreign_timeline",
          "type": "single_select",
          "label": "Planned timeline for GCC market entry",
          "required": true,
          "options": [
