        {
          "id": "foreign_industry",
          "type": "single_select_searchable",
          "label": "Industry",
          "required": true,
          "options": [
            "SaaS / B2B Software",
            "Fintech",
            "E-commerce",
            "AI / ML",
            "Marketplace",
            "Health / Medtech",
            "Education / Edtech",
            "Logistics / Supply Chain",
            "Real Estate / Proptech",
            "Food & Beverage",
            "Travel / Hospitality",
            "Retail / Fashion",
            "Media / Content",
            "Climate / Energy",
            "Other"
          ]
        },
        {
          "id": "foreign_stage",
          "type": "single_select",
          "label": "Current stage of your venture",
          "required": true,
          "options": [
            "Idea",
            "MVP built",
            "Early revenue",
            "Profitable / Scaling"
          ]
        },
        {
          "id": "foreign_one_liner",
          "type": "multi_line_text",
          "label": "Venture overview",
