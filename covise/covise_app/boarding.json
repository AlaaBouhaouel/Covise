          ]
        },
        {
          "id": "program_industries",
          "type": "multi_select_searchable",
          "label": "Industry focus",
          "required": true,
          "max_selected": 6,
          "options": [
            "SaaS / B2B Software",
            "Fintech",
            "E-commerce",
            "AI / ML",
            "Health / Medtech",
            "Education / Edtech",
            "Logistics",
            "Real Estate / Proptech",
            "Climate / Energy",
            "Food & Beverage",
            "Retail",
            "Media / Content",
            "Industry agnostic"
          ]
        },
        {
          "id": "cohort_size",
          "type": "single_select",
          "label": "Average cohort or intake size",
          "required": true,
          "options": [
            "1–5",
            "6–15",
            "16–30",
            "30+"
          ]
        },
        {
          "id": "program_offering",
          "type": "multi_select",
          "label": "Support offered to portfolio companies",
          "required": true,
          "options": [
