    {
      "step_id": "S6",
      "title": "Traction snapshot",
      "description": "A quick snapshot of your current business metrics. All fields are optional.",
      "show_if": {
        "any_of": [
          {
            "field": "stage",
            "equals": "Early revenue"
          },
          {
            "field": "stage",
            "equals": "Profitable / Scaling"
          },
          {
            "field": "foreign_stage",
            "equals": "Early revenue"
          },
          {
            "field": "foreign_stage",
            "equals": "Profitable / Scaling"
          }
        ]
      },
      "fields": [
        {
          "id": "monthly_revenue",
          "type": "single_select",
          "label": "Monthly recurring revenue (USD)",
          "required": false,
          "options": [
            "Under $1K",
            "$1K – $10K",
            "$10K – $50K",
            "$50K – $200K",
            "$200K+",
            "Prefer not to say"
          ]
        },
        {
          "id": "funding_status",
          "type": "single_select",
          "label": "Funding raised to date",
          "required": false,
          "options": [
            "Bootstrapped",
            "Friends & family round",
            "Angel round",
            "Pre-seed",
            "Seed",
            "Series A+",
            "Prefer not to say"
          ]
        },
        {
          "id": "customer_count",
          "type": "single_select",
          "label": "Active customers or paying users",
          "required": false,
          "options": [
            "1–10",
            "11–100",
            "101–1,000",
            "1,000–10,000",
            "10,000+",
            "Prefer not to say"
          ]
        }
      ]
    },
    {
      "step_id": "S7",
      "title": "Your commitment level",
      "description": "This information is used to calculate your Founder Conviction score, which is visible on your profile.",
      "show_if": {
        "any_of": [
          {
            "field": "user_type",
            "equals": "founder"
          },
          {
            "field": "user_type",
            "equals": "specialist"
          },
          {
            "field": "user_type",
            "equals": "foreign_founder"
          }
        ]
      },
      "fields": [
        {
          "id": "commitment_level",
          "type": "single_select",
          "label": "How would you describe your current level of commitment to building a venture?",
          "required": true,
          "options": [
            "Fully committed — this is my primary focus",
            "Serious — actively dedicating significant time alongside other commitments",
            "Exploring — evaluating the opportunity before committing",
            "Early stage — still defining my direction"
          ]
        },
        {
          "id": "risk_tolerance",
          "type": "single_select",
          "label": "How do you approach financial risk in a venture?",
          "required": true,
          "options": [
            "High — I am prepared to invest personal capital and work without salary",
            "Medium — I can take calculated risks with a financial runway in place",
            "Conservative — I need income stability while building",
            "Prefer to discuss with potential co-founder"
          ]
        },
