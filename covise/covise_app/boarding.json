{
  "flow_name": "Covise onboarding",
  "intro": "Set up your profile first, then continue with the deeper onboarding when you are ready.",
  "success_message": "Your onboarding is saved.",
  "steps": [
    {
      "step_id": "S1_PROFILE_COMPLETION",
      "title": "Complete your profile",
      "progress_label": "Profile completion",
      "description": "This is required before entering the feed, but only the marked fields are mandatory.",
      "fields": [
        {
          "id": "profile_image",
          "type": "file_upload_image",
          "label": "Profile photo",
          "required": false,
          "helper_text": "Optional. Add a photo now or later."
        },
        {
          "id": "headline",
          "type": "short_text",
          "label": "Headline",
          "required": false,
          "placeholder": "Founder @ X or Backend Engineer"
        },
        {
          "id": "user_type",
          "type": "single_select_card",
          "label": "What best describes you?",
          "required": true,
          "options": [
            {
              "value": "founder",
              "label": "Founder with an idea",
              "description": "I am building a venture and want the right people around it."
            },
            {
              "value": "developer",
              "label": "Developer or technical builder",
              "description": "I bring technical skill and want to build with the right venture."
            },
            {
              "value": "operator",
              "label": "Operator or specialist",
              "description": "I bring execution strength and want to build with the right venture."
            },
            {
              "value": "other",
              "label": "Other",
              "description": "My profile does not fit the main categories above."
            },
            {
              "value": "foreign_founder",
              "label": "Founder with an idea outside the GCC",
              "description": "I am based outside the GCC and exploring a local partner or market entry."
            }
          ]
        },
        {
          "id": "one_liner",
          "type": "multi_line_text",
          "label": "What are you building?",
          "required": true,
          "placeholder": "2-3 lines max about what you are building and for whom",
          "max_chars": 220
        },
        {
          "id": "looking_for_type",
          "type": "single_select_card",
          "label": "What are you looking for?",
          "required": true,
          "options": [
            "Technical co-founder",
            "Business / operational co-founder",
            "Industry expert co-founder",
            "Investor / backer",
            "Strategic advisor",
            "Local GCC partner"
          ]
        }
      ]
    },
    {
      "step_id": "S3_founder",
      "title": "Tell us about your venture",
      "progress_label": "Founder profile",
      "description": "A few more details so your profile feels useful without repeating the basics.",
      "show_if": {
        "field": "user_type",
        "equals": "founder"
      },
      "fields": [
        {
          "id": "industry",
          "type": "single_select_searchable",
          "label": "Industry",
          "required": true,
          "options": [
            "SaaS / B2B Software",
            "Fintech",
            "E-commerce",
            "AI / ML",
            "Marketplace",
            "Health / Medtech",
            "Education / Edtech",
            "Logistics / Supply Chain",
            "Real Estate / Proptech",
            "Food & Beverage",
            "Travel / Hospitality",
            "Retail / Fashion",
            "Media / Content",
            "Gaming",
            "Cybersecurity",
            "Hardware / IoT",
            "Climate / Energy",
            "Construction / Infrastructure",
            "Legal / Regtech",
            "HR / Future of Work",
            "Agri / Foodtech",
            "Consumer Apps",
            "Import / Export",
            "Other"
          ]
        },
        {
          "id": "stage",
          "type": "single_select",
          "label": "Current stage",
          "required": true,
          "options": [
            "Idea",
            "MVP built",
            "Early revenue",
            "Profitable / Scaling"
          ]
        },
        {
          "id": "target_market",
          "type": "multi_select",
          "label": "Primary target market",
          "required": true,
          "options": [
            "Saudi Arabia",
            "UAE",
            "Qatar",
            "Kuwait",
            "Bahrain",
            "Oman",
            "GCC-wide",
            "MENA-wide",
            "Global"
          ]
        }
      ]
    },
    {
      "step_id": "S3_specialist",
      "title": "Tell us about your background",
      "progress_label": "Specialist profile",
      "description": "The essentials on what you do, your experience, and where you want to build.",
      "show_if": {
        "any_of": [
          {
            "field": "user_type",
            "equals": "developer"
          },
          {
            "field": "user_type",
            "equals": "operator"
          },
          {
            "field": "user_type",
            "equals": "other"
          }
        ]
      },
      "fields": [
        {
          "id": "current_role",
          "type": "single_select",
          "label": "Current or most recent role",
          "required": true,
          "options": [
            "Software Engineer",
            "Product Manager",
            "UX / UI Designer",
            "Data Scientist / AI Engineer",
            "Marketing Manager",
            "Sales / Business Development",
            "Operations Manager",
            "Finance / CFO",
            "Legal / Compliance",
            "Consultant",
            "Other"
          ]
        },
        {
          "id": "years_experience",
          "type": "single_select",
          "label": "Years of professional experience",
          "required": true,
          "options": [
            "0-2 years",
            "3-5 years",
            "6-10 years",
            "10+ years"
          ]
        }
      ]
    },
    {
      "step_id": "S3_investor",
      "title": "Tell us about your investment profile",
      "progress_label": "Investor profile",
      "description": "A concise view of where you invest and what you want to do on Covise.",
      "show_if": {
        "field": "user_type",
        "equals": "investor"
      },
      "fields": [
        {
          "id": "investor_type",
          "type": "single_select",
          "label": "Investor type",
          "required": true,
          "options": [
            "Angel investor",
            "Venture capital",
            "Family office",
            "Strategic investor",
            "Other"
          ]
        },
        {
          "id": "investment_geography",
          "type": "multi_select",
          "label": "Geographies you actively focus on",
          "required": true,
          "options": [
            "Saudi Arabia",
            "UAE",
            "Qatar",
            "Kuwait",
            "Bahrain",
            "Oman",
            "GCC-wide",
            "MENA-wide",
            "Global"
          ]
        },
        {
          "id": "investment_stage",
          "type": "multi_select",
          "label": "Stages you invest in",
          "required": true,
          "options": [
            "Pre-seed",
            "Seed",
            "Series A",
            "Series B+",
            "All stages"
          ]
        },
        {
          "id": "investment_industries",
          "type": "multi_select_searchable",
          "label": "Industries of interest",
          "required": true,
          "max_selected": 6,
          "options": [
            "SaaS / B2B Software",
            "Fintech",
            "E-commerce",
            "AI / ML",
            "Marketplace",
            "Health / Medtech",
            "Education / Edtech",
            "Logistics / Supply Chain",
            "Real Estate / Proptech",
            "Food & Beverage",
            "Retail",
            "Media / Content",
            "Climate / Energy",
            "Consumer Apps",
            "Industry agnostic"
          ]
        },
        {
          "id": "investor_looking_for",
          "type": "single_select",
          "label": "Primary objective on Covise",
          "required": true,
          "options": [
            "Source deal flow",
            "Co-invest with other investors",
            "Mentor and support founders",
            "All of the above"
          ]
        }
      ]
    },
    {
      "step_id": "S3_foreign_founder",
      "title": "Tell us about your expansion plans",
      "progress_label": "Foreign founder",
      "description": "A few key details on your venture and what you need in the GCC.",
      "show_if": {
        "field": "user_type",
        "equals": "foreign_founder"
      },
      "fields": [
        {
          "id": "home_country",
          "type": "single_select_searchable",
          "label": "Country of residence",
          "required": true,
          "options": [
            "United States",
            "United Kingdom",
            "Germany",
            "France",
            "Netherlands",
            "Sweden",
            "Spain",
            "Italy",
            "Canada",
            "Australia",
            "India",
            "Pakistan",
            "Bangladesh",
            "Sri Lanka",
            "Turkey",
            "Egypt",
            "Jordan",
            "Lebanon",
            "Morocco",
            "Tunisia",
            "Nigeria",
            "Kenya",
            "Ghana",
            "South Africa",
            "Ethiopia",
            "Singapore",
            "Malaysia",
            "Indonesia",
            "Philippines",
            "Vietnam",
            "China",
            "South Korea",
            "Japan",
            "Brazil",
            "Mexico",
            "Other"
          ]
        },
        {
          "id": "target_gcc_market",
          "type": "multi_select",
          "label": "Target GCC market(s)",
          "required": true,
          "options": [
            "Saudi Arabia",
            "UAE",
            "Qatar",
            "Kuwait",
            "Bahrain",
            "Oman",
            "GCC-wide"
          ]
        },
        {
          "id": "foreign_industry",
          "type": "single_select_searchable",
          "label": "Industry",
          "required": true,
          "options": [
            "SaaS / B2B Software",
            "Fintech",
            "E-commerce",
            "AI / ML",
            "Marketplace",
            "Health / Medtech",
            "Education / Edtech",
            "Logistics / Supply Chain",
            "Real Estate / Proptech",
            "Food & Beverage",
            "Travel / Hospitality",
            "Retail / Fashion",
            "Media / Content",
            "Climate / Energy",
            "Other"
          ]
        },
        {
          "id": "foreign_stage",
          "type": "single_select",
          "label": "Current stage",
          "required": true,
          "options": [
            "Idea",
            "MVP built",
            "Early revenue",
            "Profitable / Scaling"
          ]
        },
        {
          "id": "local_partner_need",
          "type": "multi_select",
          "label": "What do you need from a local GCC partner?",
          "required": true,
          "max_selected": 3,
          "options": [
            "Market access and local relationships",
            "Entity setup and local operations",
            "Sales and business development",
            "Regulatory and legal navigation",
            "Investor and funding connections",
            "Cultural and language bridge"
          ]
        }
      ]
    },
    {
      "step_id": "S8",
      "title": "Finish up",
      "progress_label": "Wrap-up",
      "description": "A couple of final details and you are done.",
      "fields": [
        {
          "id": "how_heard",
          "type": "single_select",
          "label": "How did you hear about Covise?",
          "required": false,
          "options": [
            "LinkedIn",
            "Twitter / X",
            "Instagram",
            "Friend or colleague referral",
            "Google search",
            "Event or conference",
            "Other"
          ]
        },
        {
          "id": "referral_code",
          "type": "short_text",
          "label": "Referral code",
          "required": false,
          "placeholder": "e.g. COVISE-2026"
        }
      ]
    }
  ]
}
